{
  "name": "trip-canvas",
  "version": "0.1.0",
  "private": true,
  "description": "TripCanvas — AI-native travel planning prototype: natural-language trip requests become structured, editable plans with conversational input, itineraries, recommendation cards, and clear confidence/fallback states; frontend foundation for a future booking companion.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "jest",
    "test:e2e": "pnpm exec playwright test",
    "playwright:install": "pnpm exec playwright install --with-deps chromium",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx}": [
      "npm run lint",
      "npm run format"
    ],
    "*.{json,md,css,html,yml,yaml}": "npm run format"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
